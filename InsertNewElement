package Basics;

public class InsertNewElement {
    static class Node{
        int data;
        Node next;
        Node(int data){
            this.data = data;
        }
    }
    public static void main(String[] args){
        Node a = new Node(5);
        Node b = new Node(3);
        Node c = new Node(2);
        Node d = new Node(4);
        a.next = b;
        b.next = c;
        c.next = d;
        Node temp = a;
        while(temp!=null){
            System.out.print(temp.data + " ");
            temp = temp.next;
        }
        Node m = new Node(1);
        m.next = c;
        b.next = m;
        Node t = a;
        System.out.println();
        while(t!=null){
            System.out.print(t.data+" ");
            t = t.next;
        }

    }

}
