package Basics;

public class DeleteHead {
    static class Node{
        int data;
        Node next;
        Node(int data){
            this.data = data;
        }
    }
    static void printList(Node head){
        Node temp = head;
        while(temp!=null){
            System.out.print(temp.data+" ");
            temp=temp.next;
        }
        System.out.println();
    }

    public static void main() {
        Node a = new Node(5);
        Node b = new Node(2);
        Node c = new Node(1);
        a.next = b;
        b.next = c;
        printList(a);
        a = a.next;
        printList(a);

    }
}
