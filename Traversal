package Basics;

public class Traversal {
    static class Node{
        int data;
        Node next;
        Node(int data){
            this.data = data;
        }
    }
    public static void main(String[] args){
        Node head = new Node(5);
        Node a = new Node(3);
        Node b = new Node(4);
        Node c = new Node(7);
        Node tail = new Node(2);
        head.next = a;
        a.next = b;
        b.next = c;
        c.next = tail;
        Node temp = head;
        while(temp!=null){
            System.out.print(temp.data+" ");
            temp = temp.next;
        }
    }
}
