package Basics;

public class DeleteTail {
    static class Node{
        int data;
        Node next;
        Node(int data){
            this.data = data;
        }

    }
    static void printList(Node head){
        Node temp = head;
        while(temp!=null){
            System.out.print(temp.data+" ");
            temp = temp.next;
        }
        System.out.println();

    }

    public static void main() {
        Node a = new Node(5);
        Node b = new Node(3);
        Node c = new Node(4);
        a.next=b;
        b.next=c;
        printList(a);
        Node t = a;
        while(t.next.next!=null){
            t=t.next;
        }
        t.next = null;
        printList(a);
    }
}
